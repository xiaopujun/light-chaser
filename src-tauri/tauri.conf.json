{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "light-chaser",
  "version": "1.7.0",
  "identifier": "com.lightchaser.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "security": {
      "csp": null
    },
    "windows": [
      {
        "title": "light-chaser",
        "width": 1280,
        "height": 720,
        "resizable": true
      }
    ]
  }
}
